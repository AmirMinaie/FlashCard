<FlashCardListScreen>:
    name: "FlashCardListScreen"
    
    BoxLayout:
        orientation: 'vertical'
        
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(110) 
            spacing: dp(5)
            padding: [dp(10), dp(10), dp(10), 0]
            
            BoxLayout:
                size_hint_y: None
                height: dp(50)
                spacing: dp(10)

                BoxLayout:
                    size_hint_y: None
                    height: dp(50)
                    spacing: dp(5)

                    MDTextField:
                        id: search_field
                        hint_text: "search"
                        mode: "rectangle"
                        size_hint_y: None
                        height: dp(50)
                        icon_left: "magnify"
                        on_text: root.search_flashcards(self.text)

                BoxLayout:
                    size_hint_x: 0.15
                    orientation: "horizontal"
                    spacing: dp(3)
                    padding: [0,0,0,0]


                    MDLabel:
                        text: "Exact"
                        size_hint_x: None
                        width: dp(35)
                        halign: "center"
                        valign: "center"
                        font_style: "Caption"


                    MDSwitch:
                        id: exact_switch
                        size_hint_x: None
                        width: dp(40)
                        pos_hint: {"center_y": .5}
                        on_active: root.search_flashcards(search_field.text)
            
            ScrollView:
                size_hint_y: None
                height: dp(50)
                do_scroll_x: True
                do_scroll_y: False
                
                MDBoxLayout:
                    id: filter_chips_container
                    adaptive_width: True
                    spacing: dp(5)
                    padding: dp(5)
        
        # بخش پایینی (اسکرول) - لیست فلش کارت‌ها
        RecycleView:
            id: RV
            viewclass: 'MDCardA'
            scroll_type: ['bars', 'content']
            bar_width: dp(10)
            RecycleBoxLayout:
                orientation: 'vertical'
                spacing: dp(15)
                padding: dp(10)
                size_hint_y: None
                height: self.minimum_height
                default_size_hint: 1, None
                default_size: None, dp(300)