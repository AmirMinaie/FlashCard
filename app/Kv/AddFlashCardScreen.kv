<AddFlashCardScreen>:
    name: "AddFlashCardScreen"

    BoxLayout:
        orientation: "vertical"
        padding: 0
        spacing: 0

        ScrollView:
            MDBoxLayout:
                orientation: "vertical"
                spacing: "15dp"
                padding: ["20dp", "10dp", "20dp", "80dp"]  
                size_hint_y: None
                height: self.minimum_height

                MDLabel:
                    text: root.form_title
                    font_style: "H5"
                    halign: "center"
                    size_hint_y: None
                    height: dp(50)

                MDTextFieldA:
                    id: title_field
                    text_h: "Word/Title"
                    icon: "alphabetical"
                    is_required: True

                MDTextFieldA:
                    id: pronunciation_field
                    text_h: "Pronunciation"
                    icon: "volume-high"
                    is_required: True

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(60) 
                    spacing: "10dp" 

                    MDTextFieldA:
                        id: pastParticiple_field
                        text_h: "pastParticiple"
                        icon: "volume-high"

                    MDTextFieldA:
                        id: pastTense_field
                        text_h: "pastTense"
                        icon: "volume-high"

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(60) 
                    spacing: "10dp" 

                    DropDownA:
                        id: part_of_speech_field
                        text_h: "Part of Speech"
                        icon: "alphabetical-variant"
                        selected_value: ""
                        is_required: True
                        item_menu: root.load_constant('POS')

                    DropDownA:
                        id: type_field
                        text_h: "type"
                        icon: "format-list-bulleted-type"
                        selected_value: ""
                        item_menu: root.load_constant('FlashCardtype')
                        is_required: True
                    
                    DropDownA:
                        id: level_field
                        text_h: "level"
                        icon: "chart-bar"
                        selected_value: ""
                        item_menu: root.load_constant("Level")
                    
                    DropDownA:
                        id: box_field
                        text_h: "box"
                        icon: "package-variant"
                        selected_value: ""
                        item_menu: root.load_constant('Box')
                        is_required: True

                MDTextFieldA:
                    id: example_field
                    text_h: "Example Sentence"
                    icon: "format-quote-open"
                    multiline: True
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(100)
                
                MDTextFieldA:
                    id: definition_field
                    text_h: "Definition"
                    icon: "format-quote-open"
                    multiline: True
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(100)

                MDTextFieldA:
                    id: collocation_field
                    text_h: "Collocations"
                    icon: "link-variant"
                    multiline: True
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(80)
                    padding: ["0dp", "5dp"]
                

                # بخش Songs با دکمه کنار عنوان
                MDBoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: "10dp"
                    
                    # هدر بخش Songs با عنوان و دکمه
                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(50)
                        spacing: "10dp"
                        padding: ["0dp", "0dp", "10dp", "0dp"]
                        
                        MDLabel:
                            text: "Songs"
                            font_style: "H6"
                            size_hint_x: 0.8
                            size_hint_y: None
                            height: dp(50)
                            halign: "left"
                            valign: "center"
                        
                        BaseButtonA:
                            icon: "plus"
                            text: "Add Song"
                            size_hint: None, None
                            size: dp(120), dp(46)
                            pos_hint: {"center_y": 0.5}
                            md_bg_color: app.theme_cls.primary_color
                            on_release: root.show_add_song_dialog()
                    
                    # لیست Songs

                    MDList:
                        id: song_list
                        padding: "10dp"
                        spacing: "5dp"
                        size_hint_y: None
                        height: self.minimum_height
        

        MDBoxLayout:
            orientation: "horizontal"
            spacing: "10dp"
            size_hint_y: None
            height: dp(60)
            padding: ["10dp", "0dp", "10dp", "10dp"]

            BaseButtonA:
                text: "Cancel"
                icon: "close"
                size_hint_x: 0.25
                md_bg_color: app.theme_cls.primary_light
                on_release: root.cancel_edit()

            AsyncButton:
                text: "Delete"
                icon: "delete"
            
                size_hint_x: 0.25 if root.mode == "edit" else None 
                width: dp(0) if root.mode != "edit" else self.parent.width * 0.5
                opacity: 1 if root.mode == "edit" else 0
                disabled: root.mode != "edit"
            
                md_bg_color: "#D32F2F"
            
                confirm: True
                confirm_title: "Delete Flash Card"
                confirm_text: "Are you sure you want to delete this flash card?"
            
                before: root.befor_delete
                task: root.delete_card
                after: root.After_delete
                error_handler: root.handle_delete

            AsyncButton:
                text: root.save_button_text
                mode: "add"
                size_hint_x: 0.5 if root.mode == "edit" else 0.75
                before: root.befor_Save_info
                task: root.Save_info
                after: root.After_Save_info
                error_handler: root.handle_save_error