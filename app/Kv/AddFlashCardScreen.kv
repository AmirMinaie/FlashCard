<OutlineButton@MDFlatButton>:
    md_bg_color: 0, 0, 0, 0
    canvas.after:
        Color:
            rgba: app.theme_cls.primary_color
        Line:
            width: dp(1)
            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(8))


<MDTextFieldA@MDTextField>:
    text_h: ""
    icon: ""
    is_required: False
    required_color: 1, 0, 0, 1

    hint_text: root.text_h + (" *" if root.is_required else "")
    icon_left: root.icon
    
    hint_text_color: root.required_color if root.is_required and not self.text else (0.5, 0.5, 0.5, 1)
    line_color_normal: root.required_color if root.is_required and not self.text else (0, 0, 0, 1)
    
    text_color: 0, 0, 0, 1
    line_color_focus: app.theme_cls.primary_color
    size_hint_y: None
    height: dp(60)

<AddFlashCardScreen>:
    name: "AddFlashCardScreen"

    BoxLayout:
        orientation: "vertical"
        padding: 0
        spacing: 0

        ScrollView:
            MDBoxLayout:
                orientation: "vertical"
                spacing: "15dp"
                padding: ["20dp", "10dp", "20dp", "80dp"]  
                size_hint_y: None
                height: self.minimum_height

                MDLabel:
                    text: root.form_title
                    font_style: "H5"
                    halign: "center"
                    size_hint_y: None
                    height: dp(50)

                MDTextFieldA:
                    id: title_field
                    text_h: "Word/Title"
                    icon: "alphabetical"
                    is_required: True

                MDTextFieldA:
                    id: pronunciation_field
                    text_h: "Pronunciation"
                    icon: "volume-high"
                    is_required: True

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(60) 
                    spacing: "10dp" 

                    MDTextFieldA:
                        id: pastParticiple_field
                        text_h: "pastParticiple"
                        icon: "volume-high"

                    MDTextFieldA:
                        id: pastTense_field
                        text_h: "pastTense"
                        icon: "volume-high"

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(60) 
                    spacing: "10dp" 

                    DropDownA:
                        id: part_of_speech_field
                        text_h: "Part of Speech"
                        icon: "alphabetical-variant"
                        selected_value: ""
                        is_required: True
                        item_menu: root.load_constant('POS')

                    DropDownA:
                        id: type_field
                        text_h: "type"
                        icon: "format-list-bulleted-type"
                        selected_value: ""
                        item_menu: root.load_constant('FlashCardtype')
                        is_required: True
                    
                    DropDownA:
                        id: level_field
                        text_h: "level"
                        icon: "chart-bar"
                        selected_value: ""
                        item_menu: root.load_constant("Level")
                    
                    DropDownA:
                        id: box_field
                        text_h: "box"
                        icon: "package-variant"
                        selected_value: ""
                        item_menu: root.load_constant('Box')
                        is_required: True

                MDTextFieldA:
                    id: example_field
                    text_h: "Example Sentence"
                    icon: "format-quote-open"
                    multiline: True
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(100)
                
                MDTextFieldA:
                    id: definition_field
                    text_h: "Definition"
                    icon: "format-quote-open"
                    multiline: True
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(100)

                MDTextFieldA:
                    id: collocation_field
                    text_h: "Collocations"
                    icon: "link-variant"
                    multiline: True
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(80)
                    padding: ["0dp", "5dp"]
                

                # بخش Songs با دکمه کنار عنوان
                MDBoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: "10dp"
                    
                    # هدر بخش Songs با عنوان و دکمه
                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(50)
                        spacing: "10dp"
                        padding: ["0dp", "0dp", "10dp", "0dp"]
                        
                        MDLabel:
                            text: "Songs"
                            font_style: "H6"
                            size_hint_x: 0.8
                            size_hint_y: None
                            height: dp(50)
                            halign: "left"
                            valign: "center"
                        
                        MDRaisedButton:
                            icon: "plus"
                            text: "add song"
                            size_hint: None, None
                            size: dp(28), dp(28)
                            pos_hint: {"center_y": 0.5}
                            on_release: root.show_add_song_dialog()
                            elevation_normal: 8
                            md_bg_color: app.theme_cls.primary_color
                    
                    # لیست Songs
                    ScrollView:
                        size_hint_y: None
                        height: dp(200)
                        
                        MDList:
                            id: song_list
                            padding: "10dp"
                            spacing: "5dp"
                            size_hint_y: None
                            height: self.minimum_height
        

        MDBoxLayout:
            orientation: "horizontal"
            spacing: "10dp"
            size_hint_y: None
            height: dp(60)
            padding: ["10dp", "0dp", "10dp", "10dp"]

            OutlineButton:
                text: "Cancel"
                icon: "close"
                size_hint_x: 0.25
                text_color: app.theme_cls.primary_color
                on_release: root.cancel_edit()

            MDRaisedButton:
                text: "Delete"
                icon: "delete"
                size_hint_x: 0.25 if root.mode == "edit" else None
                width: dp(0) if root.mode != "edit" else self.parent.width * 0.5
                md_bg_color: 1, 0, 0, 1
                opacity: 1 if root.mode == "edit" else 0
                disabled: root.mode != "edit"
                on_release: root.confirm_delete()

            MDRaisedButton:
                text: root.save_button_text
                icon: "content-save"
                size_hint_x: 0.5 if root.mode == "edit" else 0.75
                on_release: root.Save_info()