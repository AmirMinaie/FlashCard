<ReviewScreen>:
    name: "ReviewScreen"

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(12)
        spacing: dp(8)

        ##################################################
        # Header
        ##################################################

        MDCard:
            elevation: 1
            radius: [16]
            size_hint_y: None
            height: dp(50)

            MDBoxLayout:
                padding: dp(10), dp(0)
                spacing: dp(8)

                MDLabelA:
                    id: counter_label
                    text: f"Done: {root.total_today_reviews}  | Remaining: {root.remaining_cards}"
                    font_style: "Subtitle1"
                    bold: True
                    valign: "middle"
                    halign: "left"
                    text_size: self.size

                Widget:

                MDIconButton:
                    icon: "refresh"
                    size_hint: None, None
                    size: dp(40), dp(40)
                    pos_hint: {"center_y": 0.5}
                    on_release: root.refresh_session()

        ##################################################
        # Complete Session
        ##################################################

        MDBoxLayout:
            id: compleat_Session_Box
            orientation: "vertical"
            size_hint_y: None
            height: self.minimum_height
            opacity: 0
            disabled: True
            padding: dp(20)

            MDLabelA:
                id: compleat_Session_lable
                halign: "center"
                valign: "middle"
                text_size: self.width, None
                size_hint_y: None
                height: self.texture_size[1]

        ##################################################
        # Flash Card
        ##################################################

        ScrollView:
            id: flashcard_box

            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height

                padding:  dp(10), dp(10), dp(10), dp(10)
                spacing: dp(8)
        
                MDCard:
                    orientation: "vertical"
                    size_hint_x: 1
                    size_hint_y: None
                    height: self.minimum_height
                    padding: dp(20)
                    spacing: dp(8)
                    radius: [20]
                    elevation: 2

                    ##################################################
                    # Word
                    ##################################################

                    MDLabelA:
                        id: title_label
                        text: ""
                        font_style: "H4"
                        bold: True
                        adaptive_height: True

                    MDLabelA:
                        id: pronunciation_label
                        text: ""
                        font_style: "Subtitle1"
                        theme_text_color: "Secondary"
                        adaptive_height: True

                    ##################################################
                    # Chips
                    ##################################################

                    MDBoxLayout:
                        adaptive_height: True
                        spacing: dp(8)

                        MDChipA:
                            id: pos_chip
                            icon: "alphabetical-variant"

                        MDChipA:
                            id: type_chip
                            icon: "shape"

                        MDChipA:
                            id: level_chip
                            icon: "chart-bar"

                        MDChipA:
                            id: box_chip
                            icon: "package-variant"

                    MDSeparator:

                    ##################################################
                    # Verb Forms
                    ##################################################

                    MDBoxLayout:
                        id: verb_forms_box
                        adaptive_height: True
                        padding: 0, dp(5)
                        spacing: dp(8)

                        MDLabelA:
                            text: "Past:"
                            bold: True
                            size_hint_x: None
                            width: dp(55)

                        MDLabelA:
                            id: past_tense_label
                            theme_text_color: "Secondary"

                        MDLabelA:
                            text: "Past Participle:"
                            bold: True
                            size_hint_x: None
                            width: dp(125)

                        MDLabelA:
                            id: past_participle_label
                            theme_text_color: "Secondary"

                    MDSeparator:
                        height: dp(1)

                    ##################################################
                    # Collocation
                    ##################################################

                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        spacing: dp(6)

                        MDBoxLayout:
                            adaptive_height: True
                            spacing: dp(8)

                            MDIcon:
                                icon: "format-list-bulleted"
                                theme_text_color: "Primary"
                                size_hint_x: None
                                width: dp(10)

                            MDLabelA:
                                text: "Collocations"
                                bold: True
                                font_style: "Subtitle1"

                        MDLabelA:
                            id: collocation_label
                            text: ""
                            text_size: self.width, None
                            adaptive_height: True
                            halign: "left"

                    MDSeparator:

                    ##################################################
                    # Example
                    ##################################################

                    MDBoxLayout:
                        id: example_box
                        orientation: "vertical"
                        adaptive_height: True
                        spacing: dp(6)

                        MDBoxLayout:
                            adaptive_height: True
                            spacing: dp(8)

                            MDIcon:
                                icon: "lightbulb-on-outline"
                                theme_text_color: "Primary"
                                size_hint_x: None
                                width: dp(10)

                            MDLabelA:
                                text: "Example"
                                bold: True
                                font_style: "Subtitle1"

                        MDLabelA:
                            id: example_label
                            text: ""
                            text_size: self.width, None
                            adaptive_height: True
                            halign: "left"

                    MDSeparator:

                    ##################################################
                    # Definition
                    ##################################################

                    MDBoxLayout:
                        id: definition_box
                        orientation: "vertical"
                        adaptive_height: True
                        spacing: dp(6)

                        MDBoxLayout:
                            adaptive_height: True
                            spacing: dp(8)

                            MDIcon:
                                icon: "book-open-page-variant"
                                theme_text_color: "Primary"
                                size_hint_x: None
                                width: dp(10)

                            MDLabelA:
                                text: "Definition"
                                bold: True
                                font_style: "Subtitle1"

                        MDLabelA:
                            id: definition_label
                            text: ""
                            text_size: self.width, None
                            adaptive_height: True
                            halign: "left"

                    MDSeparator:

                    ##################################################
                    # Audio
                    ##################################################
                    MDBoxLayout:
                        adaptive_height: True
                        spacing: dp(8)

                        MDIcon:
                            icon: "book-open-page-variant"
                            theme_text_color: "Primary"
                            size_hint_x: None
                            width: dp(10)

                        MDLabelA:
                            text: "Audio"
                            bold: True
                            font_style: "Subtitle1"

                    Playlist:
                        id: songs_playlist
                        size_hint_y: None
                        height: dp(150)
                        padding: dp(8), 0
                        spacing: dp(8)
                        time_slider_enabled: True
                        volume_slider_enabled: True

        BoxLayout:
            id: button_area
            orientation: "vertical"
            size_hint_y: None
            height: dp(60)
        
            MDBoxLayout:
                id: button_box
                orientation: "horizontal"
                size_hint_y: None
                height: dp(46)
                spacing: dp(10)
        
                BaseButtonA:
                    id: skip_btn
                    text: "Skip"
                    icon: "skip-next"
                    size_hint_x: 0.28
                    md_bg_color: app.theme_cls.primary_light
                    on_release: root.skip_card()
        
                BaseButtonA:
                    id: show_answer_btn
                    text: "Show Answer"
                    icon: "eye"
                    size_hint_x: 0.72
                    md_bg_color: app.theme_cls.primary_color
                    on_release: root.show_answer_fields()
        
            MDBoxLayout:
                id: answer_button_box
                orientation: "horizontal"
                size_hint_y: None
                height: 0
                opacity: 0
                disabled: True
        
                spacing: dp(10)
        
                BaseButtonA:
                    id: hide_answer_btn
                    text: "Hide"
                    icon: "eye-off"
                    size_hint_x: 1
                    md_bg_color: app.theme_cls.primary_light
                    on_release: root.hide_answer_fields()
        
                BaseButtonA:
                    id: again_btn
                    text: "Again"
                    icon: "reload-alert"
                    size_hint_x: 1
                    md_bg_color: "#D32F2F"
                    on_release: root.mark_card_quality(0)
        
                BaseButtonA:
                    id: hard_btn
                    text: "Hard"
                    icon: "alert-circle"
                    size_hint_x: 1
                    md_bg_color: "#FB8C00"
                    on_release: root.mark_card_quality(1)
        
                BaseButtonA:
                    id: good_btn
                    text: "Good"
                    icon: "thumb-up"
                    size_hint_x: 1
                    md_bg_color: "#1E88E5"
                    on_release: root.mark_card_quality(2)
        
                BaseButtonA:
                    id: easy_btn
                    text: "Easy"
                    icon: "emoticon"
                    size_hint_x: 1
                    md_bg_color: "#43A047"
                    on_release: root.mark_card_quality(3)
        
                BaseButtonA:
                    id: very_easy_btn
                    text: "Very Easy"
                    icon: "emoticon-happy"
                    size_hint_x: 1
                    md_bg_color: "#2E7D32"
                    on_release: root.mark_card_quality(4)