<HomeScreen>
    name: "HomeScreen"

    BoxLayout:
        orientation: "vertical"

        CustomTitleBar:

        MDBottomNavigation:
            id: bottom_nav
            name: "switch_tab"
            on_switch_tabs: root.on_tab_switch(*args)

            MDBottomNavigationItemA:
                name: "dashboard_tab"
                icon: "view-dashboard"
                text: "Dashboard"

                DashboardScreen:

            MDBottomNavigationItemA:
                name: "review_tab"
                icon: "clipboard-check"
                text: "Review Today"

                ReviewScreen:

            MDBottomNavigationItemA:
                name: "add_tab"
                icon: "note-plus"
                text: "Add Cards"

                AddFlashCardScreen:

            MDBottomNavigationItemA:
                name: "list_tab"
                icon: "format-list-bulleted"
                text: "List Cards"

                FlashCardListScreen: