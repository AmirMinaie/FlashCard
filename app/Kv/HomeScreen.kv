<HomeScreen>
    name: "HomeScreen"

    BoxLayout:
        orientation: "vertical"

        MDBottomNavigation:
            id: bottom_nav
            name: "switch_tab"
            on_switch_tabs: root.on_tab_switch(*args)

            MDBottomNavigationItemA:
                name: "dashboard_tab"
                icon: "view-dashboard-outline"
                text: "Dashboard"

                DashboardScreen:

            MDBottomNavigationItemA:
                name: "review_tab"
                icon: "play-circle-outline"
                text: "Review Today"

                ReviewScreen:

            MDBottomNavigationItemA:
                name: "add_tab"
                icon: "plus-circle-outline"
                text: "Add Cards"

                AddFlashCardScreen:

            MDBottomNavigationItemA:
                name: "list_tab"
                icon: "cards-outline"
                text: "List Cards"

                FlashCardListScreen: